# ============================================================
# Application
# ============================================================
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=DEBUG

# ============================================================
# OpenSearch
# ============================================================
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false
OPENSEARCH_INDEX_PREFIX=development

# ============================================================
# MongoDB
# ============================================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=realself_dev

# ============================================================
# AWS (Bedrock embeddings + SigV4 for OpenSearch)
# Leave blank when running on EC2/ECS — IAM role is used automatically
# For local dev: paste temporary SSO credentials (expire after ~1h)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-west-2

# ============================================================
# LLM
# ============================================================
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
